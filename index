        ctx.beginPath();ctx.arc(x,y,3,0,Math.PI*2);
        ctx.fillStyle='rgba(58,53,48,'+(0.09+g*0.07)+')';ctx.fill();
      });
      pulses.forEach(function(p,i){
        p.t=(p.t+p.speed)%1;
        var e=edges[i],a=nd[e[0]],b=nd[e[1]];
        var ax=a.rx*W,ay=a.ry*H,bx=b.rx*W,by=b.ry*H;
        var cpx=ax+(bx-ax)*0.5,cpy=ay+(by-ay)*0.5+(bx-ax)*0.05;
        var t=p.t;
        var px=(1-t)*(1-t)*ax+2*(1-t)*t*cpx+t*t*bx;
        var py=(1-t)*(1-t)*ay+2*(1-t)*t*cpy+t*t*by;
        var fade=Math.sin(t*Math.PI)*0.5;
        ctx.beginPath();ctx.arc(px,py,2.2,0,Math.PI*2);
        ctx.fillStyle='rgba(58,53,48,'+fade+')';ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    draw();
  })();


