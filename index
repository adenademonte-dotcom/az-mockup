<style>
*{margin:0;padding:0;box-sizing:border-box;list-style:none;}
body{font-family:'Manrope',Arial,Helvetica,sans-serif;background:#f5f1e8;overflow-x:hidden;}

/* ── ANNOUNCE ── */
.announce{background:#3d3533;padding:10px 56px;display:flex;align-items:center;justify-content:center;gap:16px;position:relative;z-index:10;}
.ann-live{display:inline-flex;align-items:center;gap:6px;background:#fd807c;border-radius:3px;padding:3px 10px;font-size:10px;font-weight:700;color:#fff;letter-spacing:0.08em;text-transform:uppercase;flex-shrink:0;}
.ann-dot{width:5px;height:5px;border-radius:50%;background:#fff;animation:blink 1.5s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.25;}}
.ann-sep{width:1px;height:13px;background:#5a5248;flex-shrink:0;}
.ann-text{font-size:13px;color:#c8c2b8;}.ann-text strong{color:#f0ece6;font-weight:600;}
.ann-cta{font-size:13px;font-weight:600;color:#f0ece6;cursor:pointer;border-bottom:1px solid rgba(240,236,230,0.3);padding-bottom:1px;white-space:nowrap;text-decoration:none;}
.ann-cta:hover{border-bottom-color:rgba(240,236,230,0.8);}

/* ── NAV ── */
.nav{background:#fff;height:68px;position:sticky;top:40px;z-index:499;display:flex;align-items:center;padding:0 48px;border-bottom:1px solid #e8e3da;position:sticky;top:0;z-index:400;}
.logo{display:flex;align-items:center;gap:9px;margin-right:44px;cursor:pointer;flex-shrink:0;text-decoration:none;}
.slashes{display:flex;gap:3px;}
.sl{width:3.5px;height:21px;background:#3d3533;border-radius:2px;transform:skewX(-14deg);}
.sl:last-child{opacity:0.3;}
.wm{font-size:20px;font-weight:700;color:#3d3533;letter-spacing:-0.3px;}
.links{display:flex;align-items:stretch;height:68px;flex:1;}
.ni{position:relative;display:flex;align-items:center;}
.nl{display:flex;align-items:center;gap:4px;padding:0 13px;height:100%;font-size:13.5px;font-weight:500;color:#3d3533;cursor:pointer;white-space:nowrap;border-bottom:3px solid transparent;transition:color 0.15s,border-color 0.15s;user-select:none;}
.nl:hover,.ni.open .nl{color:#3d3533;border-bottom-color:#fd807c;}
.arr{width:6px;height:6px;border-right:1.5px solid currentColor;border-bottom:1.5px solid currentColor;transform:rotate(45deg) translate(-1px,-2px);transition:transform 0.2s;margin-top:2px;flex-shrink:0;}
.ni.open .arr{transform:rotate(-135deg) translate(-1px,2px);}
.nav-r{display:flex;align-items:center;gap:24px;margin-left:auto;flex-shrink:0;}
.si{font-size:13.5px;font-weight:500;color:#3d3533;cursor:pointer;white-space:nowrap;background:none;border:none;font-family:inherit;}
.si:hover{color:#3d3533;}
.db{background:#fd807c;color:#fff;border:none;border-radius:5px;padding:10px 24px;font-size:13.5px;font-weight:700;cursor:pointer;font-family:'Manrope',Arial,Helvetica,sans-serif;transition:background 0.15s;white-space:nowrap;}
.db:hover{background:#e86a60;}

/* ── MEGA MENUS ── */
.mega{display:none;position:absolute;top:68px;background:#fff;border:1px solid #e8e3da;border-top:3px solid #fd807c;border-radius:0 0 12px 12px;box-shadow:0 20px 48px rgba(58,53,48,0.13);z-index:500;overflow:hidden;}
.ni.open .mega{display:flex;}
.ml{padding:22px;flex:1;display:flex;flex-direction:column;gap:14px;}
.mc{display:flex;gap:0;flex:1;}
.mcol{flex:1;padding-right:14px;}
.mcol+.mcol{border-left:1px solid #f0ece6;padding-left:14px;padding-right:0;}
.clbl{font-size:10px;font-weight:700;color:#ccc;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:8px;padding:0 6px;}
.pr{display:flex;align-items:flex-start;gap:9px;padding:7px 6px;border-radius:7px;cursor:pointer;transition:background 0.12s;}
.pr:hover{background:#f9f7f3;}
.pr:hover .pn{color:#fd807c;}
.pi{width:30px;height:30px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.pn{font-size:13px;font-weight:700;color:#3d3533;margin-bottom:2px;transition:color 0.12s;line-height:1.3;}
.pd{font-size:11.5px;color:#bbb;line-height:1.4;}
.ovs{display:flex;align-items:center;gap:11px;padding:9px 11px;border-radius:8px;background:#f9f7f3;border:1px solid #ede9e2;cursor:pointer;transition:background 0.12s;}
.ovs:hover{background:#ede9e2;}
.ovs:hover .pn{color:#fd807c;}
.oi{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.mr{width:190px;background:#f9f7f3;border-left:1px solid #f0ece6;padding:20px 16px;display:flex;flex-direction:column;gap:14px;flex-shrink:0;}
.rlbl{font-size:10px;font-weight:700;color:#ccc;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:8px;}
.fc{background:#3d3533;border-radius:9px;padding:15px;cursor:pointer;}
.fc:hover{opacity:0.9;}
.fp{display:inline-block;background:rgba(232,82,58,0.22);border-radius:3px;padding:2px 7px;font-size:9px;font-weight:700;color:#e8a090;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:8px;}
.ft{font-size:12.5px;font-weight:700;color:#f0ece6;line-height:1.4;margin-bottom:5px;}
.fb{font-size:11px;color:#7a7470;line-height:1.5;margin-bottom:9px;}
.fl{font-size:11.5px;font-weight:700;color:#e8a090;}
.sr{display:flex;align-items:center;gap:8px;padding:6px 7px;border-radius:6px;cursor:pointer;transition:background 0.12s;}
.sr:hover{background:#ede9e2;}
.sd{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.sn{font-size:12.5px;font-weight:500;color:#3d3533;}
.ss{font-size:11px;color:#bbb;margin-top:1px;}
.ib{width:26px;height:26px;border-radius:5px;background:#f0ece6;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:8.5px;font-weight:700;}

/* overlay */
.nav-ov{display:none;position:fixed;inset:0;z-index:390;}
.nav-ov.on{display:block;}

/* ── HERO ── */
.hero{padding:80px 56px 64px;text-align:center;position:relative;z-index:1;background:rgba(245,241,232,0.7);}
canvas#bgc{position:fixed;inset:0;z-index:0;pointer-events:none;}
.hero-inner{position:relative;z-index:1;}
.kicker{font-size:11px;font-weight:700;color:#aaa;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:14px;}
h1{font-size:48px;font-weight:800;color:#3d3533;line-height:1.1;letter-spacing:-1.8px;margin-bottom:32px;max-width:760px;margin-left:auto;margin-right:auto;}
.cw{height:48px;display:flex;align-items:center;justify-content:center;margin-bottom:36px;position:relative;}
.cr{position:absolute;top:0;left:0;right:0;height:48px;display:flex;align-items:center;justify-content:center;gap:12px;white-space:nowrap;opacity:0;transition:opacity 0.7s ease;}
.cr.visible{opacity:1;}
.cp{display:inline-flex;align-items:center;height:27px;padding:0 11px;border-radius:4px;font-size:10.5px;font-weight:700;letter-spacing:0.05em;color:#fff;flex-shrink:0;}
.cp.r{background:#3d3533;}.cp.b{background:#3d3533;}.cp.g{background:#3d3533;}.cp.a{background:#3d3533;}
.cd{font-size:16px;color:#666;font-weight:400;}
.ctas{display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:52px;}
.c1{background:#fd807c;color:#fff;border:none;border-radius:5px;padding:14px 34px;font-size:15px;font-weight:700;font-family:'Manrope',Arial,Helvetica,sans-serif;cursor:pointer;transition:background 0.15s;}
.c1:hover{background:#e86a60;}
.c2{background:transparent;color:#3d3533;border:1.5px solid #3d3533;border-radius:5px;padding:13px 28px;font-size:15px;font-weight:600;font-family:'Manrope',Arial,Helvetica,sans-serif;cursor:pointer;transition:all 0.15s;}
.c2:hover{background:#3d3533;color:#fff;}
.c3{background:transparent;color:#3d3533;border:1.5px solid #3d3533;border-radius:5px;padding:13px 28px;font-size:15px;font-weight:600;font-family:'Manrope',Arial,Helvetica,sans-serif;cursor:pointer;transition:all 0.15s;}
.c3:hover{background:#3d3533;color:#fff;}
.stats{display:flex;justify-content:center;max-width:540px;margin:0 auto;}
.st{flex:1;text-align:center;padding:0 28px;border-right:1px solid #dedad3;}
.st:last-child{border-right:none;}
.stat-n{font-size:32px;font-weight:800;color:#3d3533;letter-spacing:-1.5px;line-height:1;}
.stat-l{font-size:11.5px;color:#aaa;margin-top:4px;line-height:1.4;}

/* ── LOGO SCROLLER ── */
.logos-section{background:#fff;padding:36px 0;border-top:1px solid #ebe7e0;overflow:hidden;position:relative;z-index:1;}
.logos-label{text-align:center;font-size:11px;font-weight:700;color:#ddd;letter-spacing:0.16em;text-transform:uppercase;margin-bottom:28px;}
.scroller-wrap{position:relative;overflow:hidden;}
.scroller-wrap::before,.scroller-wrap::after{content:'';position:absolute;top:0;bottom:0;width:100px;z-index:2;pointer-events:none;}
.scroller-wrap::before{left:0;background:linear-gradient(to right,#fff,transparent);}
.scroller-wrap::after{right:0;background:linear-gradient(to left,#fff,transparent);}
.scroller-track{display:flex;align-items:center;width:max-content;animation:scroll 36s linear infinite;}
.scroller-track:hover{animation-play-state:paused;}
@keyframes scroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}
.logo-item{display:flex;align-items:center;justify-content:center;padding:0 32px;height:40px;flex-shrink:0;}
.logo-text{font-size:14px;font-weight:700;color:#8a8480;white-space:nowrap;transition:color 0.2s;user-select:none;}
.logo-item:hover .logo-text{color:#3d3533;}
.logo-sep{width:1px;height:16px;background:#e8e3da;flex-shrink:0;}

/* ── FADE DIVIDERS ── */
.fade-in{height:52px;background:linear-gradient(to bottom,#fff,#f9f7f3);position:relative;z-index:1;}
.fade-out{height:52px;background:linear-gradient(to bottom,#f9f7f3,#fff);position:relative;z-index:1;}

/* ── CARDS SECTION ── */
.cards-section{background:#f9f7f3;padding:56px 56px 64px;position:relative;z-index:1;}
.section-header{text-align:center;margin-bottom:44px;}
.section-kicker{font-size:11px;font-weight:700;color:#aaa;letter-spacing:0.16em;text-transform:uppercase;margin-bottom:12px;}
.section-title{font-size:26px;font-weight:800;color:#3d3533;letter-spacing:-0.8px;margin-bottom:8px;line-height:1.2;}
.section-sub{font-size:14px;color:#bbb;}
.cards{max-width:960px;margin:0 auto;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px;}
.card{background:#fff;border:1px solid #e8e3da;border-radius:14px;overflow:hidden;display:flex;flex-direction:column;transition:transform 0.2s,box-shadow 0.2s;cursor:pointer;}
.card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(58,53,48,0.09);}
.card-top{padding:24px 22px 20px;flex:1;}
.icon{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;}
.cname{font-size:14px;font-weight:800;color:#3d3533;letter-spacing:-0.3px;margin-bottom:8px;}
.cdesc{font-size:13px;color:#999;line-height:1.65;}
.card-foot{padding:14px 22px 18px;border-top:1px solid #f0ece6;}
.ctag{font-size:12.5px;font-weight:700;color:#3d3533;cursor:pointer;transition:color 0.15s;background:none;border:none;font-family:inherit;padding:0;}
.ctag:hover{color:#fd807c;}

/* ── QUOTES ── */
.quotes-section{background:#3d3533;padding:80px 56px;text-align:center;position:relative;z-index:1;}
.quote-wrap{max-width:640px;margin:0 auto;position:relative;min-height:260px;display:flex;align-items:center;justify-content:center;}
.quote-item{position:absolute;top:0;left:0;right:0;display:flex;flex-direction:column;align-items:center;opacity:0;transform:translateY(14px);transition:opacity 0.75s ease,transform 0.75s ease;pointer-events:none;padding:0 24px;}
.quote-item.on,.quote-item.visible{opacity:1;transform:translateY(0);pointer-events:auto;}
.quote-item.out,.quote-item.out,.quote-item.exit{opacity:0;transform:translateY(-14px);pointer-events:none;}
.quote-mark{font-size:52px;line-height:0.8;color:rgba(240,236,230,0.1);font-family:Georgia,serif;margin-bottom:16px;display:block;}
.quote-text{font-size:20px;font-weight:600;color:#f0ece6;line-height:1.6;letter-spacing:-0.2px;margin-bottom:28px;font-style:italic;}
.q-divider{width:32px;height:2px;background:#fd807c;border-radius:1px;margin:0 auto 22px;}
.quote-name{font-size:13px;font-weight:700;color:#c8c2b8;margin-bottom:4px;}
.quote-role{font-size:12px;color:#6a6460;}
.quote-progress{display:flex;gap:6px;align-items:center;justify-content:center;margin-top:44px;}
.qp-dot{width:20px;height:3px;border-radius:2px;background:rgba(255,255,255,0.12);transition:background 0.4s,width 0.4s;cursor:pointer;border:none;padding:0;}
.qp-dot.on{background:rgba(240,236,230,0.6);width:32px;}

/* ── WEBINAR ── */
.wb-inner-wrap{max-width:960px;margin:0 auto;}
.wb-rule{border:none;border-top:1px solid rgba(255,255,255,0.08);margin:48px 0 36px;}
.webinar-inner{display:flex;align-items:center;gap:48px;}
.wb-left{flex:1;}
.wb-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.wb-tag{background:#fd807c;color:#fff;font-size:10px;font-weight:700;border-radius:3px;padding:3px 10px;letter-spacing:0.08em;text-transform:uppercase;}
.wb-date{font-size:12px;color:#6a6460;font-weight:500;}
.wb-title{font-size:18px;font-weight:700;color:#f0ece6;line-height:1.35;margin-bottom:6px;}
.wb-desc{font-size:13px;color:#7a7470;line-height:1.6;max-width:500px;}
.wb-right{flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:10px;}
.wb-cta{background:#fd807c;color:#fff;border:none;border-radius:5px;padding:12px 26px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Manrope',Arial,Helvetica,sans-serif;transition:background 0.15s;}
.wb-cta:hover{background:#e86a60;}
.wb-sec{font-size:12px;color:#5a5450;cursor:pointer;background:none;border:none;font-family:inherit;}
.wb-sec:hover{color:#9a9490;}

/* scroll reveal */
.reveal{opacity:0;transform:translateY(18px);transition:opacity 0.65s ease,transform 0.65s ease;}
.reveal.in{opacity:1;transform:translateY(0);}

/* CASSAVA HIGHLIGHT — site-wide signature animation */
.hl{position:relative;font-weight:500;color:#3d3533;}
.hl::after{content:'';position:absolute;left:-3px;right:-3px;bottom:-1px;top:-1px;background:#fef76c;border-radius:3px;transform:scaleX(0);transform-origin:left center;transition:transform 0.55s cubic-bezier(0.22,1,0.36,1);z-index:-1;}
.cr.hl-active .hl::after{transform:scaleX(1);}
</style>
</head>
